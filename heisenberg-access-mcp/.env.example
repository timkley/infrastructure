# Required MCP bearer token. Generate on Lando with:
#   openssl rand -base64 48
HEISENBERG_ACCESS_MCP_TOKEN=

# Keep private by default. Set this to Lando's Tailscale IP only when direct
# tailnet access is intentionally desired.
HEISENBERG_ACCESS_MCP_BIND_ADDR=127.0.0.1
HEISENBERG_ACCESS_MCP_BIND_PORT=8020

# Must match the URL Codex uses for the MCP server. Keep the localhost default
# for SSH-forwarded access; use http://lando:8020/mcp when binding to Tailscale.
HEISENBERG_ACCESS_MCP_RESOURCE_URL=http://127.0.0.1:8020/mcp

# Comma-separated Host headers accepted by the MCP SDK's DNS rebinding
# protection. Add Lando's MagicDNS name and Tailscale IP when using tailnet
# access, for example: lando:8020,100.x.y.z:8020,127.0.0.1:8020,localhost:8020
HEISENBERG_ACCESS_MCP_ALLOWED_HOSTS=127.0.0.1:8020,localhost:8020

# OpenBao is reached over Docker's internal openbao_default network.
OPENBAO_ADDR=http://openbao-app:8200
OPENBAO_NETWORK=openbao_default

# Optional for later authenticated OpenBao capability checks. The current MVP
# only calls /v1/sys/health, which does not require an OpenBao token.
# OPENBAO_TOKEN=
