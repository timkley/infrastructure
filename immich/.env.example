# Copy to .env on the server and set a strong alphanumeric DB_PASSWORD.

# Uploaded original files, thumbnails, encoded videos, profiles, and Immich database backups.
UPLOAD_LOCATION=./library

# Local Postgres database files. Do not put this on a network share.
DB_DATA_LOCATION=./postgres

TZ=Europe/Berlin

# Pin Immich explicitly. Update intentionally after reading release notes.
IMMICH_VERSION=v2.7.5

# Use only A-Za-z0-9 to avoid Docker parsing issues.
DB_PASSWORD=changeMeToALongRandomAlphanumericPassword

DB_USERNAME=postgres
DB_DATABASE_NAME=immich
