# Project name (used for Traefik routing)
COMPOSE_PROJECT_NAME=clawdbot

# Docker image name (built from /opt/clawdbot source)
CLAWDBOT_IMAGE=clawdbot:local

# Generate with: openssl rand -hex 32
CLAWDBOT_GATEWAY_TOKEN=your_gateway_token_here

# Gateway binds to all interfaces (Traefik handles external access)
CLAWDBOT_GATEWAY_BIND=lan
CLAWDBOT_GATEWAY_PORT=18789

# Gmail keyring encryption password (generate with: openssl rand -hex 32)
GOG_KEYRING_PASSWORD=your_keyring_password_here

# Paths for persistent data (inside clawdbot folder)
CLAWDBOT_CONFIG_DIR=./data/.clawdbot
CLAWDBOT_WORKSPACE_DIR=./data/clawd
