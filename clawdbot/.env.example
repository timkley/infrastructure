# Clawdbot Docker Configuration

# Image name (built locally from clawdbot repo)
CLAWDBOT_IMAGE=clawdbot:local

# Path to clawdbot repository (for building the image)
# Clone to this exact path: git clone https://github.com/anthropics/clawdbot.git /opt/clawdbot
CLAWDBOT_REPO_PATH=/opt/clawdbot

# Gateway bind mode (lan or localhost)
CLAWDBOT_GATEWAY_BIND=lan

# Host directories for persistent data
CLAWDBOT_CONFIG_DIR=~/.clawdbot
CLAWDBOT_WORKSPACE_DIR=~/clawd

# Gateway token (generated by setup.sh during onboard)
CLAWDBOT_GATEWAY_TOKEN=
