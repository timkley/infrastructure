# Hetzner Storage Box — restic SFTP backend
# Copy this to backup.env and fill in your values. Never commit backup.env.

# Storage Box connection (uses SSH config alias, see setup.sh)
export RESTIC_REPOSITORY="sftp:storagebox:./backups"

# Restic encryption password (generated during setup — SAVE THIS SOMEWHERE SAFE)
export RESTIC_PASSWORD=""

# Path to infrastructure directory on the VPS
export INFRA_DIR="/opt/docker"

# Healthchecks.io ping URL (optional — leave empty to disable)
# Create a free check at https://healthchecks.io and paste the ping URL
export HEALTHCHECK_URL=""
